{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "general",
        "case",
        "service_request"
      ],
      "default": "general",
      "description": "\u0646\u0648\u0639 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629"
    },
    "case_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0627\u0644\u0642\u0636\u064a\u0629"
    },
    "service_request_id": {
      "type": "string",
      "description": "\u0645\u0639\u0631\u0641 \u0637\u0644\u0628 \u0627\u0644\u062e\u062f\u0645\u0629"
    },
    "title": {
      "type": "string",
      "description": "\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629"
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u0645\u0639\u0631\u0641\u0627\u062a \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646"
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u0623\u0633\u0645\u0627\u0621 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646"
    },
    "last_message": {
      "type": "string",
      "description": "\u0622\u062e\u0631 \u0631\u0633\u0627\u0644\u0629"
    },
    "last_message_date": {
      "type": "string",
      "description": "\u062a\u0627\u0631\u064a\u062e \u0622\u062e\u0631 \u0631\u0633\u0627\u0644\u0629"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "is_archived": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "type",
    "title"
  ]
}